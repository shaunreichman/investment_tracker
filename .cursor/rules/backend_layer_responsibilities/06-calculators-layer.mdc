        fund = session.query(Fund).filter(Fund.id == fund_id).first()  # Database access
        # ... calculation

# ❌ Bad: Instance variables and state management
class BadCalculator:
    def __init__(self):
        self.cache = {}  # State management - not allowed
    
    def calculate_something(self, data):
        if data in self.cache:  # Using instance state
            return self.cache[data]
        # ... calculation
